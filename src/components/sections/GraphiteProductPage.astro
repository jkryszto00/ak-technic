---
import PageLayout from '@layouts/PageLayout.astro';
import Button from '@components/ui/Button.astro';
import ProductSpecTable from '@components/ui/ProductSpecTable.astro';
import FeatureGrid from '@components/ui/FeatureGrid.astro';
import ContactCTA from '@components/ui/ContactCTA.astro';
import { productSchema, breadcrumbSchema } from '@utils/jsonLd';
import { graphiteProducts } from '@data/products';
import { company } from '@data/company';
import type { GraphiteProduct } from '@data/products';

interface Props {
  product: GraphiteProduct;
}

const { product } = Astro.props;

const breadcrumbs = [
  { label: 'Główna', href: '/' },
  { label: 'Oferta' },
  { label: 'Grafit EDM', href: '/oferta/grafit-edm/' },
  { label: product.name },
];

const relatedProducts = graphiteProducts.filter(p => p.id !== product.id);

const jsonLd = [
  productSchema({
    name: `Grafit EDM ${product.name} - SGL Carbon`,
    description: product.description,
    url: `https://ak-technic.pl/oferta/grafit-edm/${product.slug}/`,
  }),
  breadcrumbSchema(breadcrumbs),
];
---

<PageLayout
  title={product.seoTitle}
  description={product.seoDescription}
  breadcrumbs={breadcrumbs}
  heroTitle={`Grafit EDM ${product.name}`}
  heroSubtitle={product.shortDescription}
  jsonLd={jsonLd}
>
  <!-- Product overview -->
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
    <div data-animate="fade-right">
      <div class="flex aspect-video items-center justify-center bg-steel-100 text-steel-400">
        <svg class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    </div>

    <div data-animate="fade-left" data-delay="150">
      <h2 class="font-heading text-2xl font-bold text-steel-900">Opis produktu</h2>
      <p class="mt-4 leading-relaxed text-steel-700">{product.description}</p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <Button href="/kontakt/" variant="primary" size="lg">
          Zapytaj o cenę i dostępność
        </Button>
        <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-2 text-sm font-medium text-steel-600 hover:text-accent transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {company.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- Specifications -->
  <div class="mt-16" data-animate="fade-up">
    <ProductSpecTable specs={product.specs} />
  </div>

  <!-- Long description -->
  {product.longDescription && (
    <div class="mt-16 prose max-w-none" data-animate="fade-up">
      <h2 class="font-heading text-2xl font-bold text-steel-900">Szczegółowy opis grafitu {product.name}</h2>
      {product.longDescription.split('\n\n').map(paragraph => (
        <p class="mt-4 leading-relaxed text-steel-700">{paragraph}</p>
      ))}
    </div>
  )}

  <!-- Applications -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Zastosowania grafitu {product.name}</h3>
    <ul class="grid grid-cols-1 gap-3 md:grid-cols-2" data-stagger="60">
      {product.applications.map(app => (
        <li class="flex items-start gap-3" data-animate="fade-up">
          <svg class="mt-1 h-5 w-5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-steel-700">{app}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Advantages with descriptions -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900">Zalety grafitu {product.name}</h3>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-stagger="80">
      {product.advantages.map(adv => (
        <div class="border border-steel-200 p-6" data-animate="fade-up">
          <div class="flex items-start gap-3">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded bg-accent/10">
              <svg class="h-4 w-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <div>
              <h4 class="font-heading font-bold text-steel-900">{adv.title}</h4>
              {adv.description && (
                <p class="mt-2 text-sm leading-relaxed text-steel-600">{adv.description}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- FAQ Section -->
  {product.faq && product.faq.length > 0 && (
    <div class="mt-16">
      <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Najczęściej zadawane pytania o {product.name}</h3>
      <div class="space-y-4" data-stagger="60">
        {product.faq.map(item => (
          <details class="group border border-steel-200 bg-white" data-animate="fade-up">
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-steel-900 hover:text-accent transition-colors">
              <span>{item.question}</span>
              <svg class="h-5 w-5 shrink-0 text-steel-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-steel-200 px-6 py-4">
              <p class="leading-relaxed text-steel-700">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  )}

  <!-- How to order -->
  <div class="mt-16 border border-accent/20 bg-accent/5 p-8" data-animate="scale-in">
    <h3 class="font-heading text-xl font-bold text-steel-900">Jak zamówić grafit {product.name}?</h3>
    <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-3">
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-white">1</span>
        <div>
          <p class="font-medium text-steel-900">Wyślij zapytanie</p>
          <p class="text-sm text-steel-600">Podaj wymiary bloku i ilość — telefonicznie, mailem lub przez formularz.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-white">2</span>
        <div>
          <p class="font-medium text-steel-900">Otrzymaj wycenę w 24h</p>
          <p class="text-sm text-steel-600">Przygotujemy indywidualną ofertę z ceną, dostępnością i terminem dostawy.</p>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-accent text-sm font-bold text-white">3</span>
        <div>
          <p class="font-medium text-steel-900">Szybka dostawa</p>
          <p class="text-sm text-steel-600">Standardowe wymiary wysyłamy w 1-2 dni robocze na terenie całej Polski.</p>
        </div>
      </div>
    </div>
    <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
      <Button href="/kontakt/" variant="primary">Wyślij zapytanie ofertowe</Button>
      <span class="text-sm text-steel-600">lub zadzwoń: <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="font-medium text-accent hover:underline">{company.phone}</a></span>
    </div>
  </div>

  <!-- Related Products -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Inne gatunki grafitu EDM</h3>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3" data-stagger="100">
      {relatedProducts.map(p => (
        <a
          href={`/oferta/grafit-edm/${p.slug}/`}
          class="group border border-steel-200 p-6 transition-all hover:shadow-md hover:border-accent"
          data-animate="fade-up"
        >
          <h4 class="font-heading text-lg font-bold text-steel-900 group-hover:text-accent">{p.name}</h4>
          <p class="mt-2 text-sm text-steel-600">{p.shortDescription}</p>
          <div class="mt-3 flex items-center gap-3 text-xs text-steel-500">
            <span>Ziarno: {p.specs[0]?.value} {p.specs[0]?.unit}</span>
            <span>Gęstość: {p.specs[1]?.value} {p.specs[1]?.unit}</span>
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-16">
    <ContactCTA title={`Zainteresowany grafitem ${product.name}?`} subtitle="Skontaktuj się z nami — przygotujemy indywidualną wycenę w ciągu 24 godzin. Bezpłatne doradztwo w doborze gatunku grafitu." />
  </div>
</PageLayout>
