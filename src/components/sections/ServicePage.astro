---
import PageLayout from '@layouts/PageLayout.astro';
import Button from '@components/ui/Button.astro';
import FeatureGrid from '@components/ui/FeatureGrid.astro';
import ContactCTA from '@components/ui/ContactCTA.astro';
import { serviceSchema, breadcrumbSchema } from '@utils/jsonLd';
import { services } from '@data/services';
import { graphiteProducts } from '@data/products';
import { company } from '@data/company';
import type { Service } from '@data/services';

interface Props {
  service: Service;
}

const { service } = Astro.props;

const serviceImages: Record<string, { src: string; alt: string }> = {
  'frezowanie-grafitu-cnc': { src: '/images/services/frezowanie_grafitu.jpg', alt: 'Frezowanie grafitu CNC' },
  'toczenie-grafitu': { src: '/images/services/toczenie_grafitu.jpg', alt: 'Toczenie grafitu CNC' },
};
const image = serviceImages[service.slug];

const breadcrumbs = [
  { label: 'Główna', href: '/' },
  { label: 'Usługi', href: '/uslugi/' },
  { label: service.name },
];

const relatedServices = services.filter(s => s.id !== service.id);
const relatedProductItems = graphiteProducts.filter(p => service.relatedProducts.includes(p.id));

const jsonLd = [
  serviceSchema({
    name: service.name,
    description: service.description,
    url: `https://ak-technic.pl/uslugi/${service.slug}/`,
  }),
  breadcrumbSchema(breadcrumbs),
];
---

<PageLayout
  title={service.seoTitle}
  description={service.seoDescription}
  breadcrumbs={breadcrumbs}
  heroTitle={service.name}
  heroSubtitle={service.shortDescription}
  jsonLd={jsonLd}
>
  <!-- Description -->
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-5">
    <div class="lg:col-span-3" data-animate="fade-right">
      <h2 class="font-heading text-2xl font-bold text-steel-900">O usłudze</h2>
      <p class="mt-4 leading-relaxed text-steel-700">{service.description}</p>

      <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
        <Button href="/kontakt/" variant="primary" size="lg">
          Zapytaj o wycenę
        </Button>
        <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="inline-flex items-center gap-2 text-sm font-medium text-steel-600 hover:text-accent transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {company.phone}
        </a>
      </div>
    </div>

    <div class="lg:col-span-2" data-animate="fade-left" data-delay="150">
      {image ? (
        <img src={image.src} alt={image.alt} class="aspect-video w-full object-cover" />
      ) : (
        <div class="flex aspect-video items-center justify-center bg-steel-100 text-steel-400">
          <svg class="h-24 w-24" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
      )}
    </div>
  </div>

  <!-- Long description -->
  {service.longDescription && (
    <div class="mt-16 prose max-w-none" data-animate="fade-up">
      {service.longDescription.split('\n\n').map(paragraph => (
        <p class="leading-relaxed text-steel-700">{paragraph}</p>
      ))}
    </div>
  )}

  <!-- Capabilities -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Możliwości</h3>
    <ul class="grid grid-cols-1 gap-3 md:grid-cols-2" data-stagger="60">
      {service.capabilities.map(cap => (
        <li class="flex items-start gap-3" data-animate="fade-up">
          <svg class="mt-1 h-5 w-5 shrink-0 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="text-steel-700">{cap}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- Process -->
  {service.process && service.process.length > 0 && (
    <div class="mt-16">
      <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Proces realizacji zlecenia</h3>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-3" data-stagger="80">
        {service.process.map((step, idx) => (
          <div class="flex items-start gap-3" data-animate="fade-up">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-steel-800 text-sm font-bold text-white">{idx + 1}</span>
            <p class="text-sm leading-relaxed text-steel-700">{step}</p>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Advantages with descriptions -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900">Dlaczego AK Technic?</h3>
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3" data-stagger="80">
      {service.advantages.map(adv => (
        <div class="border border-steel-200 p-6" data-animate="fade-up">
          <h4 class="font-heading font-bold text-steel-900">{adv.title}</h4>
          {adv.description && (
            <p class="mt-2 text-sm leading-relaxed text-steel-600">{adv.description}</p>
          )}
        </div>
      ))}
    </div>
  </div>

  <!-- FAQ Section -->
  {service.faq && service.faq.length > 0 && (
    <div class="mt-16">
      <h3 class="mb-6 font-heading text-xl font-bold text-steel-900" data-animate="fade-up">Najczęściej zadawane pytania</h3>
      <div class="space-y-4" data-stagger="60">
        {service.faq.map(item => (
          <details class="group border border-steel-200 bg-white" data-animate="fade-up">
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-steel-900 hover:text-accent transition-colors">
              <span>{item.question}</span>
              <svg class="h-5 w-5 shrink-0 text-steel-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="border-t border-steel-200 px-6 py-4">
              <p class="leading-relaxed text-steel-700">{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  )}

  <!-- Related Products -->
  {relatedProductItems.length > 0 && (
    <div class="mt-16">
      <h3 class="mb-6 font-heading text-xl font-bold text-steel-900">Powiązane produkty</h3>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {relatedProductItems.map(p => (
          <a
            href={`/oferta/grafit-edm/${p.slug}/`}
            class="group border border-steel-200 p-4 transition-all hover:shadow-md hover:border-accent"
          >
            <h4 class="font-heading font-bold text-steel-900 group-hover:text-accent">Grafit {p.name}</h4>
            <p class="mt-1 text-sm text-steel-600">{p.shortDescription}</p>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Related Services -->
  <div class="mt-16">
    <h3 class="mb-6 font-heading text-xl font-bold text-steel-900">Inne usługi</h3>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {relatedServices.map(s => (
        <a
          href={`/uslugi/${s.slug}/`}
          class="group border border-steel-200 p-6 transition-all hover:shadow-md hover:border-accent"
        >
          <h4 class="font-heading font-bold text-steel-900 group-hover:text-accent">{s.name}</h4>
          <p class="mt-2 text-sm text-steel-600">{s.shortDescription}</p>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-16">
    <ContactCTA title={`Potrzebujesz usługi: ${service.name.toLowerCase()}?`} subtitle="Skontaktuj się z nami — przygotujemy bezpłatną wycenę w ciągu 24 godzin. Doradztwo techniczne w cenie." />
  </div>
</PageLayout>
