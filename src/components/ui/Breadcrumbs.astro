---
import { breadcrumbSchema } from '@utils/jsonLd';

interface Props {
  items: Array<{ label: string; href?: string }>;
  dark?: boolean;
}

const { items, dark = false } = Astro.props;
const schema = breadcrumbSchema(items);
---

<nav aria-label="Ścieżka nawigacji">
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <ol class="flex flex-wrap items-center gap-1 text-sm">
    {items.map((item, index) => (
      <li class="flex items-center">
        {index > 0 && (
          <svg class={`mx-1 h-4 w-4 ${dark ? 'text-steel-500' : 'text-steel-400'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        )}
        {item.href ? (
          <a href={item.href} class={`transition-colors ${dark ? 'text-steel-400 hover:text-white' : 'text-steel-500 hover:text-accent'}`}>
            {item.label}
          </a>
        ) : (
          <span class={dark ? 'text-white font-medium' : 'text-steel-800 font-medium'}>
            {item.label}
          </span>
        )}
      </li>
    ))}
  </ol>
</nav>
