---
interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  light?: boolean;
}

const { title, subtitle, centered = true, light = false } = Astro.props;
---

<div class={centered ? 'text-center' : ''} data-animate="fade-up">
  <h2 class={`font-heading text-2xl font-bold md:text-3xl ${light ? 'text-white' : 'text-steel-900'}`}>
    {title}
  </h2>
  <div class={`mt-3 h-1 w-16 bg-gradient-to-r from-accent to-primary ${centered ? 'mx-auto' : ''}`}></div>
  {subtitle && (
    <p class={`mt-4 text-lg ${light ? 'text-steel-300' : 'text-steel-600'}`}>
      {subtitle}
    </p>
  )}
</div>
