---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  [key: string]: unknown;
}

const { href, variant = 'primary', size = 'md', class: className = '', ...rest } = Astro.props;

const baseClasses = 'group/btn inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2';

const variants = {
  primary: 'bg-accent text-white border-2 border-accent hover:bg-orange-600 hover:border-orange-600 hover:shadow-lg hover:shadow-accent/25',
  secondary: 'bg-transparent text-white border-2 border-white hover:bg-white/10',
  dark: 'bg-transparent text-steel-800 border-2 border-steel-800 hover:bg-steel-800 hover:text-white',
};

const sizes = {
  sm: 'px-4 py-2 text-sm',
  md: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const classes = `${baseClasses} ${variants[variant]} ${sizes[size]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} {...rest}>
  <slot />
  {href && (
    <svg class="h-4 w-4 transition-transform duration-200 group-hover/btn:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  )}
</Tag>
