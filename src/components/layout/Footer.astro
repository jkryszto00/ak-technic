---
import { company } from '@data/company';
import { footerLinks } from '@data/navigation';
---

<footer class="bg-steel-900 text-steel-300">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
      <!-- Column 1: Company -->
      <div>
        <a href="/"><img src="/images/logo/logo-aktechnic.png" alt="AK Technic - Logo" class="h-10 w-auto brightness-0 invert" /></a>
        <p class="mt-4 text-sm leading-relaxed">
          {company.description}
        </p>
        <div class="mt-4 inline-flex items-center gap-2 border border-accent/30 bg-accent/10 px-3 py-1.5 text-xs font-medium text-accent">
          <img src="/images/logo/sgl-carbon-logo.svg" alt="SGL Carbon" class="h-4 w-auto brightness-0 invert" />
          Oficjalny dystrybutor
        </div>
      </div>

      <!-- Column 2: Firma -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">Firma</h3>
        <ul class="mt-4 space-y-2">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="link-underline text-sm transition-colors hover:text-accent">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Produkty i Usługi -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">Produkty</h3>
        <ul class="mt-4 space-y-2">
          {footerLinks.products.map(link => (
            <li>
              <a href={link.href} class="link-underline text-sm transition-colors hover:text-accent">{link.label}</a>
            </li>
          ))}
        </ul>
        <h3 class="mt-6 font-heading text-sm font-bold uppercase tracking-wider text-white">Usługi</h3>
        <ul class="mt-4 space-y-2">
          {footerLinks.services.map(link => (
            <li>
              <a href={link.href} class="link-underline text-sm transition-colors hover:text-accent">{link.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h3 class="font-heading text-sm font-bold uppercase tracking-wider text-white">Kontakt</h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <span class="block font-medium text-white">{company.fullName}</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="mt-0.5 h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>{company.address.street}<br />{company.address.postalCode} {company.address.city}</span>
          </li>
          <li>
            <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="flex items-center gap-2 hover:text-accent transition-colors">
              <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              {company.phone}
            </a>
          </li> 
          <li>
            <a href={`mailto:${company.email}`} class="flex items-center gap-2 hover:text-accent transition-colors">
              <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              {company.email}
            </a>
          </li>
          <li class="text-xs text-steel-500">{company.hours}</li>
        </ul>
      </div>
    </div>
    <div>
      <span class="text-xs">powered by <a href="https://jkryszto.com/?referer=ak-technic.pl" target="_blank" class="text-accent">jkryszto.com</a></span>
    </div>
  </div>
</footer>
