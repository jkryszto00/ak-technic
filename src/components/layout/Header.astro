---
import DesktopDropdown from './DesktopDropdown.tsx';
import MobileMenu from './MobileMenu.tsx';
import { mainNavigation } from '@data/navigation';
import { company } from '@data/company';
---

<!-- Top bar -->
<div class="bg-steel-900 text-sm text-steel-300">
  <div class="mx-auto flex max-w-7xl items-center justify-end-safe px-4 py-2 sm:px-6 lg:px-8">
    <div class="flex items-center gap-4 text-xs">
      <a href={`tel:${company.phone.replace(/\s/g, '')}`} class="flex items-center gap-1 hover:text-white transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        {company.phone}
      </a>
      <a href={`mailto:${company.email}`} class="flex items-center gap-1 hover:text-white transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
        {company.email}
      </a>
    </div>
  </div>
</div>

<!-- Main header -->
<header class="sticky top-0 z-40 border-b border-steel-200 bg-white/95 backdrop-blur-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center">
      <img src="/images/logo/logo-aktechnic.png" alt="AK Technic - Logo" class="h-10 w-auto" />
    </a>

    <!-- Desktop navigation -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Nawigacja główna">
      {mainNavigation.map(item => (
        item.children ? (
          <DesktopDropdown client:load item={item} />
        ) : (
          <a
            href={item.href}
            class="px-3 py-2 text-sm font-medium text-steel-700 transition-colors hover:text-accent"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- CTA + Mobile menu -->
    <div class="flex items-center gap-3">
      <a
        href="/kontakt/"
        class="hidden bg-accent px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-orange-600 hover:shadow-lg hover:shadow-accent/25 sm:inline-block"
      >
        Kontakt
      </a>
      <MobileMenu client:load navigation={mainNavigation} />
    </div>
  </div>
</header>
