---
export const prerender = true;
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '@utils/categories';
import { breadcrumbSchema } from '@utils/jsonLd';

export async function getStaticPaths() {
  const allArticles = await getCollection('blog', ({ data }) => !data.draft);
  const uniqueCategories = [...new Set(allArticles.map(a => a.data.category))];

  return uniqueCategories.map(cat => ({
    params: { category: cat },
    props: {
      categoryId: cat,
      categoryName: categories[cat as keyof typeof categories] || cat,
      articles: allArticles
        .filter(a => a.data.category === cat)
        .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()),
    },
  }));
}

const { categoryId, categoryName, articles } = Astro.props;
const categoryEntries = Object.entries(categories) as [string, string][];

const breadcrumbs = [
  { label: 'Główna', href: '/' },
  { label: 'Baza wiedzy', href: '/baza-wiedzy/' },
  { label: categoryName },
];
---

<PageLayout
  title={`${categoryName} - Baza wiedzy AK Technic`}
  description={`Artykuły z kategorii ${categoryName} w bazie wiedzy AK Technic.`}
  breadcrumbs={breadcrumbs}
  heroTitle={categoryName}
  heroSubtitle={`Artykuły i poradniki z kategorii ${categoryName}`}
  jsonLd={breadcrumbSchema(breadcrumbs)}
>
  <!-- Category filters -->
  <div class="mb-10 flex flex-wrap gap-2" data-animate="fade-up">
    <a
      href="/baza-wiedzy/"
      class="inline-block border border-steel-300 px-4 py-2 text-sm font-medium text-steel-700 transition-colors hover:border-accent hover:text-accent"
    >
      Wszystkie
    </a>
    {categoryEntries.map(([id, name]) => (
      <a
        href={`/baza-wiedzy/kategoria/${id}/`}
        class:list={[
          'inline-block border px-4 py-2 text-sm font-medium transition-colors',
          id === categoryId
            ? 'border-accent bg-accent text-white'
            : 'border-steel-300 text-steel-700 hover:border-accent hover:text-accent',
        ]}
      >
        {name}
      </a>
    ))}
  </div>

  {articles.length === 0 ? (
    <p class="text-center text-steel-600">Brak artykułów w tej kategorii.</p>
  ) : (
    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {articles.map(article => {
        const date = article.data.publishDate;
        return (
          <a
            href={`/baza-wiedzy/${article.id}/`}
            class="group flex flex-col border border-steel-200 bg-white transition-all hover:shadow-lg hover:-translate-y-1"
          >
            <div class="flex aspect-[16/9] items-center justify-center bg-steel-100 text-steel-400">
              <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-2">
                <span class="inline-block rounded bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">
                  {categories[article.data.category as keyof typeof categories] || article.data.category}
                </span>
                <time datetime={date.toISOString()} class="text-xs text-steel-400">
                  {date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h2 class="mt-3 font-heading text-lg font-bold text-steel-900 group-hover:text-accent transition-colors">
                {article.data.title}
              </h2>
              <p class="mt-2 flex-1 text-sm text-steel-600">{article.data.description}</p>
              <span class="mt-4 inline-flex items-center text-sm font-medium text-accent">
                Czytaj więcej
                <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  )}
</PageLayout>
