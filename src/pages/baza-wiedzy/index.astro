---
export const prerender = true;
import PageLayout from '@layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { categories } from '@utils/categories';
import { breadcrumbSchema } from '@utils/jsonLd';

const allArticles = await getCollection('blog', ({ data }) => !data.draft);
const articles = allArticles.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const breadcrumbs = [
  { label: 'Główna', href: '/' },
  { label: 'Baza wiedzy' },
];

const categoryEntries = Object.entries(categories) as [string, string][];
---

<PageLayout
  title="Baza wiedzy - artykuły o graficie EDM i obróbce CNC"
  description="Baza wiedzy AK Technic - artykuły, poradniki i przewodniki dotyczące grafitu EDM, obróbki elektroerozyjnej, frezowania CNC i materiałów eksploatacyjnych."
  breadcrumbs={breadcrumbs}
  heroTitle="Baza wiedzy"
  heroSubtitle="Artykuły, poradniki i przewodniki dotyczące grafitu EDM, obróbki CNC i technologii przemysłowych"
  jsonLd={breadcrumbSchema(breadcrumbs)}
>
  <div class="prose max-w-none mb-8" data-animate="fade-up">
    <p>
      Zapraszamy do lektury naszej bazy wiedzy, w której dzielimy się wieloletnim doświadczeniem
      w branży obróbki elektroerozyjnej i frezowania CNC. Znajdziesz tu praktyczne poradniki
      dotyczące doboru gatunków grafitu EDM, optymalizacji parametrów obróbki, konserwacji maszyn
      i wyboru materiałów eksploatacyjnych. Nasze artykuły adresujemy do technologów, operatorów
      maszyn CNC i EDM, konstruktorów form oraz osób odpowiedzialnych za zakupy w narzędziowniach.
      Regularnie publikujemy nowe treści, dlatego warto zaglądać tu co jakiś czas.
    </p>
  </div>

  <!-- Search -->
  <div class="mb-6" data-animate="fade-up">
    <input
      type="text"
      id="article-search"
      placeholder="Szukaj artykułu po tytule..."
      class="w-full border border-steel-300 bg-white px-4 py-3 text-sm text-steel-900 placeholder:text-steel-400 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
    />
  </div>

  <!-- Category filters -->
  <div class="mb-10 flex flex-wrap gap-2" data-animate="fade-up">
    <a
      href="/baza-wiedzy/"
      class="inline-block border border-accent bg-accent px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-accent/90"
    >
      Wszystkie
    </a>
    {categoryEntries.map(([id, name]) => (
      <a
        href={`/baza-wiedzy/kategoria/${id}/`}
        class="inline-block border border-steel-300 px-4 py-2 text-sm font-medium text-steel-700 transition-colors hover:border-accent hover:text-accent"
      >
        {name}
      </a>
    ))}
  </div>

  {articles.length === 0 ? (
    <p class="text-center text-steel-600">Artykuły pojawią się wkrótce.</p>
  ) : (
    <div id="articles-grid" class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {articles.map(article => {
        const date = article.data.publishDate;
        return (
          <a
            href={`/baza-wiedzy/${article.id}/`}
            class="article-card group flex flex-col border border-steel-200 bg-white transition-all hover:shadow-lg hover:-translate-y-1"
            data-title={article.data.title.toLowerCase()}
          >
            <div class="flex aspect-[16/9] items-center justify-center bg-steel-100 text-steel-400">
              <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-2">
                <span class="inline-block rounded bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">
                  {categories[article.data.category as keyof typeof categories] || article.data.category}
                </span>
                <time datetime={date.toISOString()} class="text-xs text-steel-400">
                  {date.toLocaleDateString('pl-PL', { year: 'numeric', month: 'short', day: 'numeric' })}
                </time>
              </div>
              <h2 class="mt-3 font-heading text-lg font-bold text-steel-900 group-hover:text-accent transition-colors">
                {article.data.title}
              </h2>
              <p class="mt-2 flex-1 text-sm text-steel-600">{article.data.description}</p>
              <span class="mt-4 inline-flex items-center text-sm font-medium text-accent">
                Czytaj więcej
                <svg class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </span>
            </div>
          </a>
        );
      })}
    </div>
  )}

  <p id="no-results" class="hidden text-center text-steel-600 mt-8">
    Nie znaleziono artykułów pasujących do wyszukiwania.
  </p>
</PageLayout>

<script>
  const searchInput = document.getElementById('article-search') as HTMLInputElement;
  const cards = document.querySelectorAll('.article-card');
  const noResults = document.getElementById('no-results');

  searchInput?.addEventListener('input', () => {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    cards.forEach(card => {
      const title = card.getAttribute('data-title') || '';
      const matches = !query || title.includes(query);
      (card as HTMLElement).style.display = matches ? '' : 'none';
      if (matches) visibleCount++;
    });

    if (noResults) {
      noResults.classList.toggle('hidden', visibleCount > 0);
    }
  });
</script>
