---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
---

<BaseLayout title="Strona nie znaleziona" noindex={true}>
  <section class="flex min-h-[60vh] items-center justify-center px-4 py-20">
    <div class="text-center">
      <span class="text-6xl font-bold text-accent">404</span>
      <h1 class="mt-4 font-heading text-3xl font-bold text-steel-900">Strona nie została znaleziona</h1>
      <p class="mx-auto mt-4 max-w-md text-steel-600">
        Przepraszamy, ale strona której szukasz nie istnieje lub została przeniesiona.
      </p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <Button href="/" variant="primary">Strona główna</Button>
        <Button href="/oferta/grafit-edm/" variant="dark">Nasze produkty</Button>
        <Button href="/kontakt/" variant="dark">Kontakt</Button>
      </div>
    </div>
  </section>
</BaseLayout>
